<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>
<?import io.github.palexdev.materialfx.controls.MFXButton?>

<?import javafx.scene.layout.GridPane?>
<VBox fx:controller="io.github.palexdev.materialfx.demo.controllers.TournoisController"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1">
    <GridPane
            styleClass="scroll-pane"
            stylesheets="@../css/TournoisCard.css">
        <FlowPane fx:id="addButtonContainer" hgap="20" vgap="20" alignment="CENTER">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <MFXButton fx:id="addTournamentButton" text="Add Tournament"
                       styleClass="Add-button"
                       stylesheets="@../css/TournoisCard.css"
                       onAction="#handleAddNewTournament"/>
        </FlowPane>
    </GridPane>


    <ScrollPane fitToWidth="true"
                styleClass="scroll-pane"
                stylesheets="@../css/TournoisCard.css">
        <FlowPane fx:id="cardsContainer" hgap="20" vgap="20" alignment="CENTER">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <!-- Dynamic tournament cards will be added here by the controller -->
        </FlowPane>
    </ScrollPane>



</VBox>